# MemoLens Pi Configuration
# Copy this to .env and fill in your values

# Required: Your patient's UUID from the database
PATIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Backend WebSocket URL for video streaming
# Replace localhost with your backend server IP if running remotely
BACKEND_WS_URL=ws://localhost:8000/ws/stream/${PATIENT_ID}

# Backend API URL for voice queries
BACKEND_API_URL=http://localhost:8000/api/v1

# Optional: JWT token for authenticated voice queries
# Get this by logging in via the frontend or API
AUTH_TOKEN=

# Voice settings (defaults shown)
VOICE_ENABLED=true
VOICE_ANNOUNCE_PERSONS=true
VOICE_ANNOUNCE_REMINDERS=true
